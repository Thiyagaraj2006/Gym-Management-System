import mysql.connector

# Database Connection
db = mysql.connector.connect(
    host="localhost",
    user="root",
    password="root",
    database="gym_management"
)

cursor = db.cursor()

# Add Member
def add_member():
    name = input("Enter Member Name: ")
    age = int(input("Enter Age: "))
    gender = input("Enter Gender: ")
    phone = input("Enter Phone Number: ")
    membership_plan = input("Enter Membership Plan: ")

    query = """
    INSERT INTO members (name, age, gender, phone, membership_plan)
    VALUES (%s, %s, %s, %s, %s)
    """

    values = (name, age, gender, phone, membership_plan)

    cursor.execute(query, values)
    db.commit()

    print("Member Added Successfully!")

# View Members
def view_members():
    cursor.execute("SELECT * FROM members")
    members = cursor.fetchall()

    print("\n===== Member Records =====")

    for member in members:
        print(member)

# Search Member
def search_member():
    member_id = int(input("Enter Member ID: "))

    query = "SELECT * FROM members WHERE id = %s"
    values = (member_id,)

    cursor.execute(query, values)
    member = cursor.fetchone()

    if member:
        print(member)
    else:
        print("Member Not Found!")

# Update Member
def update_member():
    member_id = int(input("Enter Member ID to Update: "))

    name = input("Enter New Name: ")
    age = int(input("Enter New Age: "))
    gender = input("Enter New Gender: ")
    phone = input("Enter New Phone Number: ")
    membership_plan = input("Enter New Membership Plan: ")

    query = """
    UPDATE members
    SET name=%s, age=%s, gender=%s, phone=%s, membership_plan=%s
    WHERE id=%s
    """

    values = (
        name,
        age,
        gender,
        phone,
        membership_plan,
        member_id
    )

    cursor.execute(query, values)
    db.commit()

    print("Member Updated Successfully!")

# Delete Member
def delete_member():
    member_id = int(input("Enter Member ID to Delete: "))

    query = "DELETE FROM members WHERE id=%s"
    values = (member_id,)

    cursor.execute(query, values)
    db.commit()

    print("Member Deleted Successfully!")

# Main Menu
while True:
    print("\n===== Gym Management System =====")
    print("1. Add Member")
    print("2. View Members")
    print("3. Search Member")
    print("4. Update Member")
    print("5. Delete Member")
    print("6. Exit")

    choice = input("Enter Your Choice: ")

    if choice == '1':
        add_member()

    elif choice == '2':
        view_members()

    elif choice == '3':
        search_member()

    elif choice == '4':
        update_member()

    elif choice == '5':
        delete_member()

    elif choice == '6':
        print("Exiting Program...")
        break

    else:
        print("Invalid Choice!")
